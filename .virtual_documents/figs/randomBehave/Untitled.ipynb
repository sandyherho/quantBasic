    """Print a welcome message."""
    clear_screen()
    print("\n" + "=" * 80)
    print(" " * 25 + "BLACK-SCHOLES OPTION CALCULATOR")
    print(" " * 30 + "by Sandy Herho")
    print(" " * 25 + "License: WTFPL - Do What The F*** You Want To Public License")
